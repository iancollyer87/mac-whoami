#!/bin/zsh
# ============================================================
#  mac-whoami — macOS Privacy & Anonymity Tool
#  Modeled after kali-whoami by owerdogan
#  Built for macOS (Apple Silicon & Intel)
#  GitHub: https://github.com/iancollyer87/mac-whoami
# ============================================================

VERSION="1.0.0"
BACKUP_DIR="$HOME/.mac-whoami/backups"
LOG_FILE="/var/log/mac-whoami.log"
INTERFACE="en0"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

banner() {
  echo "${CYAN}"
  echo "  ╔╦╗╔═╗╔═╗  ╦ ╦╦ ╦╔═╗╔═╗╔╦╗╦"
  echo "  ║║║╠═╣║    ║║║╠═╣║ ║╠═╣║║║║"
  echo "  ╩ ╩╩ ╩╚═╝  ╚╩╝╩ ╩╚═╝╩ ╩╩ ╩╩═╝"
  echo "${WHITE}  macOS Privacy & Anonymity Tool v${VERSION}${NC}"
  echo "${YELLOW}  ⚠  No such thing as 100% anonymity!${NC}"
  echo ""
}

log() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') | $1" >> $LOG_FILE 2>/dev/null
  echo "${GREEN}[✔]${NC} $1"
}
warn() { echo "${YELLOW}[!]${NC} $1"; }
err()  { echo "${RED}[✘]${NC} $1"; }
info() { echo "${CYAN}[i]${NC} $1"; }

backup() {
  mkdir -p "$BACKUP_DIR"
  ifconfig $INTERFACE | grep ether | awk '{print $2}' > "$BACKUP_DIR/mac.bak"
  scutil --get ComputerName > "$BACKUP_DIR/hostname.bak" 2>/dev/null
  networksetup -getdnsservers Wi-Fi > "$BACKUP_DIR/dns.bak" 2>/dev/null
  readlink /etc/localtime > "$BACKUP_DIR/timezone.bak" 2>/dev/null
  log "Backups saved to $BACKUP_DIR"
}

change_mac() {
  info "Changing MAC address..."
  networksetup -setairportpower $INTERFACE off 2>/dev/null
  sleep 2
  NEW_MAC="02:$(openssl rand -hex 5 | sed 's/\(..\)/\1:/g; s/.$//')"
  ifconfig $INTERFACE ether $NEW_MAC 2>/dev/null
  networksetup -setairportpower $INTERFACE on 2>/dev/null
  sleep 2
  log "MAC address changed → $NEW_MAC"
}

restore_mac() {
  if [[ -f "$BACKUP_DIR/mac.bak" ]]; then
    OLD_MAC=$(cat "$BACKUP_DIR/mac.bak")
    networksetup -setairportpower $INTERFACE off 2>/dev/null
    sleep 1
    ifconfig $INTERFACE ether $OLD_MAC 2>/dev/null
    networksetup -setairportpower $INTERFACE on 2>/dev/null
    log "MAC address restored → $OLD_MAC"
  else
    warn "No MAC backup found"
  fi
}

change_dns() {
  info "Changing DNS to privacy-focused servers..."
  networksetup -setdnsservers Wi-Fi 1.1.1.1 9.9.9.9 2>/dev/null
  dscacheutil -flushcache 2>/dev/null
  killall -HUP mDNSResponder 2>/dev/null
  log "DNS changed → Cloudflare (1.1.1.1) + Quad9 (9.9.9.9)"
}

restore_dns() {
  networksetup -setdnsservers Wi-Fi "Empty" 2>/dev/null
  dscacheutil -flushcache 2>/dev/null
  killall -HUP mDNSResponder 2>/dev/null
  log "DNS restored to ISP default"
}

change_hostname() {
  info "Randomizing hostname..."
  WORDS=("phantom" "shadow" "ghost" "cipher" "nexus" "vertex" "aurora" "stealth" "vortex" "eclipse")
  RAND_WORD=${WORDS[$RANDOM % ${#WORDS[@]}]}
  RAND_NUM=$((RANDOM % 9000 + 1000))
  NEW_HOST="${RAND_WORD}-${RAND_NUM}"
  scutil --set ComputerName "$NEW_HOST" 2>/dev/null
  scutil --set HostName "$NEW_HOST" 2>/dev/null
  scutil --set LocalHostName "$NEW_HOST" 2>/dev/null
  log "Hostname changed → $NEW_HOST"
}

restore_hostname() {
  if [[ -f "$BACKUP_DIR/hostname.bak" ]]; then
    OLD_HOST=$(head -1 "$BACKUP_DIR/hostname.bak")
    scutil --set ComputerName "$OLD_HOST" 2>/dev/null
    scutil --set HostName "$OLD_HOST" 2>/dev/null
    scutil --set LocalHostName "$OLD_HOST" 2>/dev/null
    log "Hostname restored → $OLD_HOST"
  fi
}

change_timezone() {
  info "Setting timezone to UTC..."
  systemsetup -settimezone UTC 2>/dev/null
  log "Timezone set → UTC"
}

restore_timezone() {
  if [[ -f "$BACKUP_DIR/timezone.bak" ]]; then
    OLD_TZ=$(cat "$BACKUP_DIR/timezone.bak" | sed 's|.*/zoneinfo/||')
    systemsetup -settimezone "$OLD_TZ" 2>/dev/null
    log "Timezone restored → $OLD_TZ"
  fi
}

kill_logs() {
  info "Clearing system logs..."
  rm -rf ~/Library/Logs/* 2>/dev/null
  rm -f /var/log/wifi.log /var/log/system.log 2>/dev/null
  > ~/.zsh_history 2>/dev/null
  > ~/.bash_history 2>/dev/null
  history -p 2>/dev/null
  log "Logs cleared"
}

enable_firewall() {
  info "Enabling firewall + stealth mode..."
  /usr/libexec/ApplicationFirewall/socketfilterfw --setglobalstate on 2>/dev/null
  /usr/libexec/ApplicationFirewall/socketfilterfw --setstealthmode on 2>/dev/null
  log "Firewall enabled + stealth mode on"
}

disable_firewall_stealth() {
  /usr/libexec/ApplicationFirewall/socketfilterfw --setstealthmode off 2>/dev/null
  log "Firewall stealth mode disabled"
}

clear_caches() {
  info "Clearing caches..."
  find ~/Library/Caches -mindepth 1 -maxdepth 1 -not -name "CloudKit" -exec rm -rf {} + 2>/dev/null
  rm -rf /tmp/* 2>/dev/null
  log "Caches cleared"
}

disable_diagnostics() {
  info "Disabling crash reporter and diagnostics..."
  defaults write com.apple.CrashReporter DialogType none 2>/dev/null
  log "Diagnostics suppressed"
}

enable_diagnostics() {
  defaults delete com.apple.CrashReporter DialogType 2>/dev/null
  log "Diagnostics restored"
}

show_status() {
  echo ""
  echo "${WHITE}══════════════════ STATUS ══════════════════${NC}"
  CURRENT_MAC=$(ifconfig $INTERFACE | grep ether | awk '{print $2}')
  ORIGINAL_MAC=$(cat "$BACKUP_DIR/mac.bak" 2>/dev/null || echo "unknown")
  CURRENT_HOST=$(scutil --get ComputerName 2>/dev/null)
  CURRENT_DNS=$(networksetup -getdnsservers Wi-Fi 2>/dev/null | tr '\n' ' ')
  CURRENT_TZ=$(systemsetup -gettimezone 2>/dev/null | awk '{print $3}')
  FW_STATUS=$(/usr/libexec/ApplicationFirewall/socketfilterfw --getglobalstate 2>/dev/null | awk '{print $NF}')
  echo "${CYAN}  MAC Address  :${NC} $CURRENT_MAC"
  [[ "$CURRENT_MAC" != "$ORIGINAL_MAC" ]] && echo "                ${GREEN}↑ Spoofed${NC}" || echo "                ${YELLOW}↑ Original (not spoofed)${NC}"
  echo "${CYAN}  Hostname     :${NC} $CURRENT_HOST"
  echo "${CYAN}  DNS Servers  :${NC} $CURRENT_DNS"
  echo "${CYAN}  Timezone     :${NC} $CURRENT_TZ"
  echo "${CYAN}  Firewall     :${NC} $FW_STATUS"
  echo "${WHITE}════════════════════════════════════════════${NC}"
  echo ""
}

show_help() {
  echo ""
  echo "${WHITE}  Usage:${NC} sudo mac-whoami [OPTION]"
  echo ""
  echo "  ${GREEN}--start${NC}     Backup settings and activate all privacy modules"
  echo "  ${GREEN}--stop${NC}      Deactivate all modules and restore original settings"
  echo "  ${GREEN}--status${NC}    Show current privacy status"
  echo "  ${GREEN}--logs${NC}      Clear system logs only"
  echo "  ${GREEN}--mac${NC}       Randomize MAC address only"
  echo "  ${GREEN}--fix${NC}       Emergency restore of all original settings"
  echo "  ${GREEN}--help${NC}      Show this help menu"
  echo ""
}

banner

case "$1" in
  --start)
    echo "${WHITE}  Starting all privacy modules...${NC}\n"
    backup
    change_mac
    change_dns
    change_hostname
    change_timezone
    kill_logs
    enable_firewall
    disable_diagnostics
    clear_caches
    echo ""
    log "mac-whoami started — all modules active ✔"
    show_status
    ;;
  --stop)
    echo "${WHITE}  Stopping all modules, restoring settings...${NC}\n"
    restore_mac
    restore_dns
    restore_hostname
    restore_timezone
    enable_diagnostics
    disable_firewall_stealth
    echo ""
    log "mac-whoami stopped — settings restored ✔"
    show_status
    ;;
  --status)
    show_status
    ;;
  --logs)
    kill_logs
    ;;
  --mac)
    change_mac
    ;;
  --fix)
    echo "${WHITE}  Running fix — restoring all original settings...${NC}\n"
    restore_mac
    restore_dns
    restore_hostname
    restore_timezone
    enable_diagnostics
    log "Fix complete ✔"
    show_status
    ;;
  --help|*)
    show_help
    ;;
esac
